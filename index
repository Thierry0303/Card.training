      <button class="quiz-opt" onclick="answer('8-2',1,1)"><span class="quiz-opt-letter">B</span>Multiple small transactions from different cards on the same IP/device in a short window</button>
      <button class="quiz-opt" onclick="answer('8-2',2,1)"><span class="quiz-opt-letter">C</span>Foreign IP address rule</button>
      <button class="quiz-opt" onclick="answer('8-2',3,1)"><span class="quiz-opt-letter">D</span>Weekend transaction rule</button>
    </div>
    <div class="quiz-feedback" id="qfb-8-2"></div>
