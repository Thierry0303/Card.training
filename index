  }
}

// ── Quiz engine ────────────────────────────────────────────────────────────
function answer(lessonId, chosen, correct) {
  const opts = document.querySelectorAll(`#lesson-${lessonId.replace('-','\\-')} .quiz-opt`);
  opts.forEach(o => { o.disabled = true; o.style.pointerEvents = 'none'; });
  opts[chosen].classList.add(chosen === correct ? 'correct' : 'wrong');
  if (chosen !== correct) opts[correct].classList.add('correct');

  const isRight = chosen === correct;
  const expMap = EXPLANATIONS[lessonId] || {};
  const exp = expMap[chosen] || (isRight ? 'Correct!' : 'Not quite — re-read the lesson for the explanation.');

  const fb = document.getElementById('qfb-' + lessonId);
  if (fb) {
    fb.className = 'quiz-feedback show ' + (isRight ? 'ok' : 'no');
    fb.textContent = (isRight ? '✓ ' : '✗ ') + exp;
  }

  if (!quizState[lessonId]) quizState[lessonId] = {score:0};
  if (isRight) quizState[lessonId].score++;
  lss('qstate', quizState);

  const scoreEl = document.getElementById('qs-' + lessonId);
  if (scoreEl) scoreEl.textContent = quizState[lessonId].score + ' correct';

  const nextBtn = document.getElementById('qn-' + lessonId);
  if (nextBtn) nextBtn.style.display = 'inline-block';

  // Auto-mark complete on correct answer
  if (isRight && !done[lessonId]) {
    setTimeout(() => markDone(lessonId), 1200);
  }
}

function nextQ(lessonId) {
  // Single-question quizzes — just hide the next button
  const nextBtn = document.getElementById('qn-' + lessonId);
  if (nextBtn) nextBtn.style.display = 'none';
}

// ── Certs ────────────────────────────────────────────────────────────────────
function renderCerts() {
  var groups = [
    { id:'basics',   lessons: CH1.concat(CH2),     name:'Payments Foundations',        icon:'\uD83D\uDCDA', desc:'Chapters 1 & 2 — Beginner' },
    { id:'security', lessons: CH3.concat(CH4),     name:'Payments Security',           icon:'\uD83D\uDD10', desc:'Chapters 3 & 4 — Beginner' },
    { id:'beginner', lessons: ALL.slice(0,12),     name:'Payments 101 — Complete',     icon:'\uD83C\uDF93', desc:'All 12 beginner lessons' },
    { id:'inter',    lessons: INT_ALL,             name:'Intermediate Practitioner',   icon:'\u26A1', desc:'Module 2 — 12 lessons' },
    { id:'advanced', lessons: ADV_ALL,             name:'Advanced Specialist',         icon:'\uD83C\uDFC6', desc:'Module 3 — 10 lessons' }
  ];
  var earned = '';
  groups.forEach(function(g) {
    var n = g.lessons.filter(function(l){ return done[l]; }).length;
    var isEarned = n === g.lessons.length;
    var card = document.getElementById('cert-' + g.id);
    var prog = document.getElementById('cp-' + g.id);
    if (card) card.classList.toggle('earned', isEarned);
    var badgeEl = card ? card.querySelector('.cert-badge-icon') : null;
    if (badgeEl) badgeEl.style.filter = isEarned ? 'none' : 'grayscale(1)';
    if (prog) {
      if (isEarned) {
        var d = new Date(Math.max.apply(null, g.lessons.map(function(l){ return done[l] || 0; })));
        prog.textContent = '\u2713 Earned ' + d.toLocaleDateString('en-GB', {day:'numeric', month:'long', year:'numeric'});
      } else {
        prog.textContent = n + ' / ' + g.lessons.length + ' lessons complete';
      }
      prog.className = 'cert-progress' + (isEarned ? ' earned-label' : '');
    }
    if (isEarned) {
      earned += '<div style="background:linear-gradient(135deg,#d8f3dc,#f0fdf4);border:1.5px solid #a7f3d0;border-radius:14px;padding:22px 24px;margin-bottom:12px;display:flex;align-items:center;gap:18px">'
        + '<span style="font-size:36px">' + g.icon + '</span>'
        + '<div>'
        + '<div style="font-family:var(--serif);font-size:18px;font-weight:500;color:#1a3d2b;margin-bottom:3px">' + g.name + '</div>'
        + '<div style="font-size:13px;color:#2d6a4f">' + g.desc + ' \u00B7 Certificate of completion</div>'
        + '</div></div>';
    }
  });
  var area = document.getElementById('earned-area');
  if (area) {
    area.innerHTML = earned || '<p style="color:var(--ink3);font-size:14px">Complete the lessons to earn your certificates.</p>';
  }
  var certN = groups.filter(function(g){ return g.lessons.every(function(l){ return done[l]; }); }).length;
  var sc = document.getElementById('stat-cert');
  if (sc) sc.textContent = certN;
}

</script>
