let done = ls('done',{});
let quizState = ls('qstate',{});

const EXPLANATIONS = {
  '1-1': {2:'Exactly right! Your bank is the only one that knows your balance, your spending history, and whether the card is valid. Visa and Mastercard route the question — but your bank gives the answer.',0:'Not quite — the shop\'s till sends the question, but it doesn\'t make the decision. That\'s your bank\'s job.',1:'Visa and Mastercard route the message to your bank, but they don\'t actually decide whether to approve it.',3:'Governments have no role in individual card payment approvals — that\'s entirely between banks.'},
  '1-2': {1:'Correct! The issuer is the bank that gave you the card. Monzo issued the card, holds the money, and makes the approval decision. Visa is just the network connecting everyone.',0:'The shop is the merchant — they receive the payment, but they don\'t issue cards.',2:'Visa is the card scheme/network — they route the transaction but don\'t hold the customer\'s money.',3:'The coffee shop\'s bank is the acquirer — they process payments for the merchant.'},
  '1-3': {2:'Correct! The shop gets the approval immediately, but the actual money transfer (settlement) happens the next business day or two. Weekends add to the delay.',0:'Approval is instant, but that\'s just permission to charge — not the actual money moving.',1:'The batch process happens at end of day, but the money itself doesn\'t arrive until the next working day or two.',3:'The money moves during settlement, which is typically T+1 or T+2 — not when you check your statement.'},
  '2-1': {1:'Correct! 51–55 is the classic Mastercard range. They also use the 2221–2720 range for newer cards. Starting with 5 alone isn\'t enough — it needs to be specifically 51–55.',0:'Cards starting with 4 are Visa, not 5. The network is identified by the first digit(s).',2:'Amex starts with 34 or 37 and has 15 digits, not 16.',3:'You absolutely can tell — the first few digits identify the network reliably.'},
  '2-2': {1:'Spot on! The chip generates a unique cryptographic code for every transaction. Even if someone captures it, it only worked for that one payment and can\'t be reused. This makes chip cloning essentially impossible.',0:'Chips don\'t store data in an external database — they contain their own secure microprocessor.',2:'Chips use cryptographic keys, not biometrics. Your fingerprint isn\'t used at the chip level (that\'s a phone feature for contactless).',3:'Chips do store some data — but more importantly, they generate unique transaction codes each time.'},
  '2-3': {1:'Most likely answer. When everything else is fine, a fraud flag from your bank is the most common culprit — especially if the purchase looks unusual. Check your banking app immediately.',0:'Card readers rarely fail on a single card while working for others. If your card declines and others work, the issue is with your card/bank.',2:'Major network outages are very rare and would affect everyone at that terminal, not just your card.',3:'Your banking app has no bearing on whether your physical card is accepted at a shop terminal.'},
  '3-1': {2:'Exactly right. In-store, you need the physical card plus your PIN — two things a fraudster is unlikely to have together. Online, only the card number, expiry and CVV are needed — information that can be copied, stolen, or phished.',0:'Online payments go through the same Visa and Mastercard networks — the routing is identical.',1:'Banks absolutely check balances for online payments — the authorisation process is essentially the same.',3:'Banks monitor online transactions very carefully — often more than in-store, precisely because fraud is more common.'},
  '3-2': {1:'Absolutely right. This is one of the most common scams. The fraudster has already submitted a fraudulent transaction that needs your OTP to complete. Never share OTP codes with anyone who calls you.',0:'Your real bank will never ask for your OTP code over the phone. This is always a fraud attempt.',2:'Sharing any part of the code is dangerous — it might be enough for the fraudster.',3:'Emailing a code is just as dangerous. The scammer just needs the digits.'},
  '4-1': {2:'Perfect response. Phishing links take you to convincing fake sites. Always navigate directly to websites by typing the address yourself, never through links in emails.',0:'This is exactly what phishing scams want you to do. Genuine companies don\'t ask you to "urgently verify" card details via email.',1:'Even if they say it\'s real, don\'t share the link — instead, go directly to Amazon by typing it in your browser.',3:'Replying confirms your email is active and may lead to further scam attempts — and still doesn\'t tell you if it\'s real.'},
  '4-2': {2:'Correct! You have strong protections here. Section 75 of the Consumer Credit Act means your credit card company shares liability for purchases between £100–£30,000. Even without Section 75, you can raise a chargeback claim.',0:'Card payments come with strong consumer protections specifically for situations like this. You have rights.',1:'The administrator may take months or years to resolve, and card holders are typically unsecured creditors. Your card protection is much faster and more reliable.',3:'Individual cardholders don\'t contact Visa or Mastercard directly — you go through your card issuer (bank).'},
  '5-1': {2:'Exactly right. The processing fee (Merchant Discount Rate) is split between multiple parties: your bank gets the largest share (interchange), Visa/Mastercard gets a network fee, and the airline\'s bank gets an acquiring fee.',0:'There\'s no government payment tax on individual card transactions (VAT is a separate matter on the purchase price itself).',1:'The card reader just reads the card — the money doesn\'t stay there!',3:'There\'s always a fee. The question is who pays it and how much — it\'s just not charged to you as the customer.'},
  '6-1': {1:'Correct! An unfamiliar country and IP address are high-risk signals. Your bank wants to verify you\'re really there — a challenge is very likely even if the amount is small.',0:'3DS doesn\'t have a blanket approval under £100 — every transaction is scored individually based on all available context.',2:'Banks don\'t block all overseas online transactions automatically — they assess each one. Many will approve with a challenge.',3:'3DS applies globally, not just domestically.'},
  '6-2': {0:'Correct! When a merchant claims a SCA exemption and the transaction is later fraudulent, they retain the fraud liability. The tradeoff for less friction is absorbing the risk.',1:'The amount being low doesn\'t shift liability to the issuer — what matters is who authenticated (or didn\'t) and who claimed the exemption.',2:'Visa and Mastercard don\'t absorb fraud losses — they set the rules for who does.',3:'Cardholders are reimbursed for fraud — they don\'t bear the loss.'},
  '6-3': {0:'Correct! MIT exemptions allow merchants to initiate subsequent charges without 3DS after the cardholder has authenticated the initial transaction and consented to recurring billing.',1:'SCA has multiple defined exemptions — MIT for recurring billing being one of the most widely used.',2:'MIT exemption is not amount-based — it\'s based on the nature of the transaction (merchant-initiated after consent).',3:'SCA applies across the EU and UK regardless of country.'},
  '7-1': {2:'Correct! Tokens are bound to a specific device and require a unique cryptographic code (generated in the device\'s secure element) for each transaction. Stolen tokens are useless without the device.',0:'Both tokens and card numbers can be encrypted — that\'s not the key difference. The difference is the device binding and per-transaction cryptogram.',1:'There\'s no government token insurance scheme.',3:'Tokens don\'t expire automatically after 24 hours — they remain active for the life of the card/device relationship.'},
  '7-2': {1:'Correct! The verification text approves the creation and secure storage of a DPAN token on your specific device — not a current payment. Your bank is authorising the token provisioning.',0:'No payment is being initiated when adding a card to Apple Pay — it\'s a provisioning, not a transaction.',2:'Apple doesn\'t get account management access — they receive only the token, not your banking credentials.',3:'Contactless limits are set separately — adding to Apple Pay doesn\'t change your limit.'},
  '8-1': {2:'Correct! Multiple high-risk signals combine: unknown device fingerprint, VPN/datacenter IP, high-risk merchant category (digital goods), large amount with no prior history — the combined score would be very high.',0:'Real card details don\'t make a transaction appear legitimate — context matters enormously. All the other signals would still trigger risk flags.',1:'Amount is just one signal — modern risk systems use dozens simultaneously.',3:'Banks have access to device data, behavioural data, merchant data, and much more beyond just IP.'},
  '8-2': {1:'Correct! Card testing typically involves many small charges from different card numbers but the same IP or device — the velocity on that device/IP is what triggers the rule.',0:'The amounts are small — amount thresholds wouldn\'t trigger on 50p transactions.',2:'The foreign IP rule alone wouldn\'t specifically catch card testing from a domestic IP.',3:'There are no standard weekend transaction rules — fraud happens every day of the week.'},
  '9-1': {2:'Correct! If a merchant doesn\'t respond within the deadline, the chargeback is automatically accepted. The cardholder wins by default and the merchant absorbs the transaction amount plus fees.',0:'Merchants absolutely must respond to defend — silence means automatic loss.',1:'The scheme doesn\'t investigate on the merchant\'s behalf — that\'s the merchant\'s responsibility.',3:'Response windows are strict — typically 20–45 days, not 6 months.'},
  '9-2': {0:'Correct! Visa 10.4 is a fraud chargeback under the Allocation workflow — if 3DS was completed, liability automatically shifts to the issuer. The merchant wins without needing to provide evidence.',1:'For 10.4 with 3DS, liability shift applies automatically — delivery proof is not required for fraud codes under Allocation.',2:'Arbitration fees only apply if the case escalates to that stage — liability shift from 3DS resolves it much earlier.',3:'10.4 chargebacks can absolutely be disputed — 3DS authentication is a complete defence.'},
  '10-1': {1:'Correct! Premium travel cards have higher interchange rates because the issuer needs more revenue to fund the generous rewards. That higher interchange comes from the merchant\'s MDR — effectively subsidising cardholder benefits.',0:'Processing complexity doesn\'t vary significantly by card type — the fee difference is entirely about interchange.',2:'Premium cardholders are generally lower fraud risk, not higher.',3:'The fee percentage is set by interchange tables, not by the individual transaction amount.'},
  '10-2': {1:'Correct! When card data never touches the merchant\'s servers (hosted fields/iframes), their PCI scope shrinks dramatically to SAQ A — a short self-assessment with minimal requirements.',0:'Full audit is only required for Level 1 merchants processing millions of transactions or those who store card data themselves.',2:'PCI DSS applies to any entity that accepts card payments — not just banks and large retailers.',3:'Hosted field solutions specifically exist so merchants don\'t need to store card data themselves.'},
  '10-3': {2:'Correct! Travel businesses face high chargeback rates because customers cancel flights and holidays — often months after payment. The rolling reserve protects the acquirer from being left with chargebacks after paying out the merchant.',0:'Rolling reserves are a commercial risk management tool, not a legal requirement.',1:'Acquirers don\'t invest reserves — they hold them as a chargeback buffer.',3:'Reserve requirements vary significantly by industry and risk profile — travel and new businesses face higher requirements.'},
  '11-1': {2:'Correct! MTI 0110 = Authorisation Response (issuer → terminal). DE 39 = "51" = Insufficient Funds. So: the issuer responded to the authorisation request declining it for insufficient funds.',0:'An approval would have DE 39 = "00" and include an authorisation code in DE 38.',1:'Reversals use MTI 0400/0420 — not 0110.',3:'Financial requests use MTI 0200/0210, not 0110.'},
  '11-2': {1:'Correct! Under DMS, the original authorisation was for £500 — a ceiling, not a fixed charge. The hotel captures £347 (the actual amount), and the £153 hold is released. This is standard DMS partial capture.',0:'Charging more than the capture amount would be incorrect — and potentially a scheme violation.',2:'Issuing a refund after charging the full amount is inefficient and costs additional processing fees — partial capture is the correct approach.',3:'Voiding and re-authorising is unnecessary with DMS — partial capture is designed exactly for this scenario.'},
  '12-1': {1:'Correct! "C" in the ARes means Challenge Required. The cardholder must authenticate — via OTP, biometric, or push notification — before the payment can proceed.',0:'The transaction is not declined — it\'s paused pending cardholder authentication. Declined is returned as "N".',2:'Phone calls are for manual authorisation (referral scenarios) — not 3DS challenges.',3:'"Y" means frictionless approval, not "C". "C" explicitly requires a challenge interaction.'},
  '12-2': {1:'Correct! ECI 06 means 3DS was attempted but the ACS was unable to authenticate (returned U). Liability still shifts to the issuer because the merchant made a good-faith attempt — the issuer\'s system failed, not the merchant\'s.',0:'ECI 06 is "attempted" not "failed in a way that harms the merchant" — liability still shifts.',2:'Visa doesn\'t absorb fraud losses — the issuer does when ECI 06 is present.',3:'There\'s no 50/50 split — liability is binary based on ECI value.'},
  '13-1': {1:'Correct! When a physical card is reported lost/stolen, the issuer should suspend associated tokens as a precaution — the thief might have access to the card number and potentially the device. Suspension allows quick reactivation once a new card is issued.',0:'Tokens are linked to the card\'s PAN — a reported lost card means the PAN may be compromised, so tokens must be reviewed.',2:'Tokens can be suspended and reactivated — deactivation and re-provisioning is a more drastic step.',3:'Visa/Mastercard don\'t notify individual merchants about token status — that\'s handled through the issuer/TSP relationship.'},
  '13-2': {1:'Correct! The issuer (cardholder\'s bank) has final approval authority. They verify the cardholder\'s identity and decide whether to allow the token to be provisioned on that device.',0:'Apple/Google initiate the request but cannot approve it — that requires the issuer\'s consent.',2:'Visa/Mastercard manage the TSP infrastructure but the issuance decision requires explicit issuer approval.',3:'Mobile networks play no role in card token provisioning.'},
  '14-1': {2:'Correct! ML can discover and exploit complex, non-linear combinations of features that would never be expressed as a human-written rule. This is the key advantage over rule-based systems for novel fraud patterns.',0:'ML models are not always more accurate — they require significant training data, feature engineering, and tuning. Rule-based systems often outperform in edge cases.',1:'ML inference is typically similar cost to rules — and training is significantly more expensive.',3:'Both ML and rule-based systems can access the same data — the difference is how they process it.'},
  '14-2': {1:'Correct! Lowering the threshold blocks more predictions as fraud — which catches more actual fraud but also incorrectly blocks more legitimate customers. This is the precision-recall trade-off that every fraud team manages daily.',0:'There\'s always a trade-off — tightening any model threshold increases false positives alongside true positives.',2:'Decision speed doesn\'t change significantly with threshold adjustments.',3:'Interchange rates are unaffected by the merchant\'s internal fraud model settings.'},
  '15-1': {2:'Correct! A 1.2% chargeback ratio triggers both Visa\'s VDMP (threshold 0.65%) and Mastercard\'s ECP (threshold 1%). Both programmes include escalating monthly fines if the ratio doesn\'t improve.',0:'Both schemes\' monitoring programmes trigger within 1–2 months of breaching thresholds — not 6 months.',1:'Interchange rates don\'t change due to chargeback ratios — fines are assessed separately.',3:'Scheme monitoring triggers merchant-level consequences (fines, potential termination) — schemes don\'t contact cardholders directly.'},
  '15-2': {1:'Correct! CE 3.0 specifically requires matching device fingerprint (or device ID) AND IP address from prior transactions. Purchase history alone — without device data — doesn\'t qualify.',0:'Purchase history is necessary but not sufficient — device fingerprint matching is a mandatory requirement.',2:'Email address is not one of the CE 3.0 matching criteria — device fingerprint and IP are required.',3:'CE 3.0 has specific, mandatory requirements — not any combination of prior data the merchant happens to have.'},
  '5-2': {2:'Correct! Card payment settlement typically takes 1–2 working days. Friday\'s payments arrive Monday at the earliest — and if there\'s a bank holiday it could be later. Planning cash flow around this is a real challenge for small businesses.',0:'Settlement doesn\'t happen at midnight — it goes through a batch clearing process that takes at least a working day.',1:'Individual taps look instant because the approval is instant, but the money movement is a separate, slower process.',3:'Cardholders and merchants can\'t override settlement timing by contacting Visa directly — it\'s a systemic process.'},
};

