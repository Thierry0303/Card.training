      <button class="quiz-opt" onclick="answer('1-1',2,2)"><span class="quiz-opt-letter">C</span>Your bank — they check your balance and decide</button>
      <button class="quiz-opt" onclick="answer('1-1',3,2)"><span class="quiz-opt-letter">D</span>The government</button>
    </div>
    <div class="quiz-feedback" id="qfb-1-1"></div>
