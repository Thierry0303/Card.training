<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Payments 101 — How Card Payments Work</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,500;0,700;1,300;1,500&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --cream:#fdf8f2;
  --cream2:#f5ede0;
  --cream3:#ede0cc;
  --ink:#1c1410;
  --ink2:#3d2f24;
  --ink3:#6b5744;
  --rust:#c4522a;
  --rust-light:#f5e6df;
  --teal:#1a6b6b;
  --teal-light:#e0f0f0;
  --gold:#b8860b;
  --gold-light:#fef9e7;
  --green:#2d6a4f;
  --green-light:#d8f3dc;
  --border:#e8d9c7;
  --shadow:0 2px 16px rgba(28,20,16,.08);
  --shadow-lg:0 8px 40px rgba(28,20,16,.12);
  --r:12px;
  --sans:'DM Sans',sans-serif;
  --serif:'Fraunces',Georgia,serif;
  --mono:'DM Mono',monospace;
}

html{scroll-behavior:smooth}
body{font-family:var(--sans);background:var(--cream);color:var(--ink);font-size:16px;line-height:1.65;min-height:100vh;overflow-x:hidden}

/* ── LAYOUT ── */
.app{display:flex;min-height:100vh}
.sidebar{width:260px;background:var(--ink);color:#f5ede0;flex-shrink:0;position:fixed;top:0;left:0;height:100vh;overflow-y:auto;z-index:200;transition:transform .3s cubic-bezier(.4,0,.2,1)}
.main{margin-left:260px;flex:1;display:flex;flex-direction:column;min-width:0}

/* ── SIDEBAR ── */
.sidebar-top{padding:24px 20px 16px}
.sidebar-logo{display:flex;align-items:center;gap:10px;margin-bottom:6px}
.logo-mark{width:32px;height:32px;background:var(--rust);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.logo-text{font-family:var(--serif);font-size:17px;font-weight:500;color:#fdf8f2;letter-spacing:-.01em}
.sidebar-tagline{font-size:11px;color:#8a7060;letter-spacing:.04em;text-transform:uppercase;margin-bottom:20px}
.sidebar-progress{margin-bottom:8px}
.progress-label{display:flex;justify-content:space-between;font-size:11px;color:#8a7060;margin-bottom:6px}
.progress-track{height:4px;background:rgba(255,255,255,.1);border-radius:2px;overflow:hidden}
.progress-bar{height:100%;background:var(--rust);border-radius:2px;transition:width .5s ease;width:0%}
.sidebar-nav{padding:8px 0 24px}
.nav-section{padding:12px 20px 4px;font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:#5c4535;font-weight:600}
.nav-btn{display:flex;align-items:center;gap:10px;width:100%;padding:9px 20px;font-family:var(--sans);font-size:13px;color:#c8b8a8;background:none;border:none;cursor:pointer;text-align:left;transition:all .15s;border-left:3px solid transparent;line-height:1.3}
.nav-btn:hover{color:#fdf8f2;background:rgba(255,255,255,.05)}
.nav-btn.active{color:#fdf8f2;border-left-color:var(--rust);background:rgba(196,82,42,.15)}
.nav-btn.done{color:#7ab89a}
.nav-btn.done .nav-check{opacity:1}
.nav-num{font-family:var(--mono);font-size:10px;color:#5c4535;width:18px;flex-shrink:0;font-weight:500}
.nav-check{font-size:11px;margin-left:auto;opacity:0;transition:opacity .2s;color:#7ab89a}

/* ── TOPBAR ── */
.topbar{position:sticky;top:0;z-index:100;background:rgba(253,248,242,.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);padding:0 40px;height:56px;display:flex;align-items:center;justify-content:space-between}
.topbar-crumb{font-size:13px;color:var(--ink3);font-weight:500}
.topbar-right{display:flex;align-items:center;gap:12px}
.topbar-badge{font-size:11px;font-family:var(--mono);color:var(--ink3);background:var(--cream2);border:1px solid var(--border);padding:3px 10px;border-radius:99px}
.menu-btn{display:none;background:none;border:none;cursor:pointer;color:var(--ink);font-size:22px;padding:4px}
.overlay{display:none;position:fixed;inset:0;background:rgba(28,20,16,.5);z-index:150;backdrop-filter:blur(2px)}
.overlay.show{display:block}

/* ── CONTENT AREA ── */
.content{max-width:760px;margin:0 auto;padding:48px 40px 80px}

/* ── LESSON PAGES ── */
.lesson{display:none;animation:fadeUp .4s ease}
.lesson.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}

/* ── HOME / DASHBOARD ── */
.hero-card{background:linear-gradient(135deg,var(--ink) 0%,#3d2015 100%);border-radius:20px;padding:48px;margin-bottom:36px;position:relative;overflow:hidden;color:var(--cream)}
.hero-card::before{content:'';position:absolute;top:-60px;right:-60px;width:240px;height:240px;background:radial-gradient(circle,rgba(196,82,42,.4),transparent 70%);pointer-events:none}
.hero-card::after{content:'💳';position:absolute;bottom:-20px;right:32px;font-size:120px;opacity:.07;line-height:1}
.hero-eyebrow{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--rust);margin-bottom:14px;font-weight:600}
.hero-title{font-family:var(--serif);font-size:38px;font-weight:300;line-height:1.15;margin-bottom:14px;letter-spacing:-.02em}
.hero-title em{font-style:italic;color:#f5c4a0}
.hero-sub{font-size:15px;color:#c8b8a8;max-width:480px;line-height:1.7;margin-bottom:28px}
.hero-start-btn{display:inline-flex;align-items:center;gap:8px;background:var(--rust);color:#fff;border:none;padding:14px 28px;border-radius:10px;font-family:var(--sans);font-size:15px;font-weight:600;cursor:pointer;transition:all .2s}
.hero-start-btn:hover{background:#a84020;transform:translateY(-1px);box-shadow:0 6px 20px rgba(196,82,42,.4)}
.hero-start-btn span{font-size:18px}

/* Stats row */
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:36px}
.stat-box{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:18px;text-align:center}
.stat-val{font-family:var(--serif);font-size:28px;font-weight:500;color:var(--rust);display:block;margin-bottom:4px}
.stat-label{font-size:12px;color:var(--ink3)}

/* Chapter cards */
.chapter-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:36px}
.chapter-card{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:20px;cursor:pointer;transition:all .2s;position:relative;overflow:hidden}
.chapter-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--border)}
.chapter-card.c1::before{background:var(--rust)}
.chapter-card.c2::before{background:var(--teal)}
.chapter-card.c3::before{background:var(--gold)}
.chapter-card.c4::before{background:var(--green)}
.chapter-card.c5::before{background:#7c3aed}
.chapter-card:hover{border-color:var(--cream3);transform:translateY(-2px);box-shadow:var(--shadow)}
.chapter-emoji{font-size:28px;margin-bottom:10px;display:block}
.chapter-num{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--ink3);font-weight:600;margin-bottom:5px}
.chapter-title{font-family:var(--serif);font-size:16px;font-weight:500;margin-bottom:6px;letter-spacing:-.01em}
.chapter-desc{font-size:12px;color:var(--ink3);line-height:1.5;margin-bottom:12px}
.chapter-meta{font-size:11px;color:var(--ink3);font-family:var(--mono);display:flex;align-items:center;gap:8px}
.chapter-done-badge{background:var(--green-light);color:var(--green);font-size:10px;padding:2px 8px;border-radius:99px;font-family:var(--mono);font-weight:500}

/* ── LESSON LAYOUT ── */
.lesson-header{margin-bottom:36px;padding-bottom:28px;border-bottom:1px solid var(--border)}
.lesson-eyebrow{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--rust);font-weight:600;margin-bottom:10px}
.lesson-title{font-family:var(--serif);font-size:34px;font-weight:300;line-height:1.2;margin-bottom:12px;letter-spacing:-.02em;color:var(--ink)}
.lesson-lead{font-size:17px;color:var(--ink3);max-width:580px;line-height:1.7}

.lesson h3{font-family:var(--serif);font-size:22px;font-weight:500;margin:36px 0 14px;letter-spacing:-.01em;color:var(--ink)}
.lesson h4{font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--ink3);margin:28px 0 10px}
.lesson p{font-size:15px;color:var(--ink2);line-height:1.8;margin-bottom:16px}
.lesson ul,.lesson ol{margin:0 0 16px 20px}
.lesson li{font-size:15px;color:var(--ink2);line-height:1.7;margin-bottom:6px}

/* Callout boxes */
.box{border-radius:var(--r);padding:20px 22px;margin:20px 0;display:grid;grid-template-columns:36px 1fr;gap:12px;align-items:start}
.box-icon{font-size:20px;margin-top:2px}
.box-title{font-weight:600;font-size:14px;margin-bottom:5px}
.box-text{font-size:14px;line-height:1.65;opacity:.9}
.box.story{background:var(--cream2);border-left:3px solid var(--rust);color:var(--ink2)}
.box.insight{background:var(--teal-light);border-left:3px solid var(--teal);color:#0d3d3d}
.box.warning{background:#fff8e6;border-left:3px solid var(--gold);color:#4a3300}
.box.good{background:var(--green-light);border-left:3px solid var(--green);color:#0d2d1a}
.box.simple{background:var(--rust-light);border-left:3px solid var(--rust);color:#4a1800}

/* Flow visual */
.flow-wrap{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:24px;margin:20px 0;overflow-x:auto}
.flow{display:flex;align-items:center;gap:0;flex-wrap:nowrap;min-width:400px}
.flow-node{background:var(--cream2);border:1.5px solid var(--border);border-radius:10px;padding:12px 16px;text-align:center;flex-shrink:0}
.flow-node.lit{background:var(--rust-light);border-color:var(--rust)}
.flow-node.teal{background:var(--teal-light);border-color:var(--teal)}
.flow-node-icon{font-size:22px;display:block;margin-bottom:4px}
.flow-node-name{font-size:12px;font-weight:600;color:var(--ink);display:block}
.flow-node-role{font-size:10px;color:var(--ink3);display:block;margin-top:2px}
.flow-arrow{padding:0 10px;color:var(--cream3);font-size:20px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;gap:2px}
.flow-arrow-label{font-size:9px;color:var(--ink3);font-family:var(--mono);white-space:nowrap}

/* Table */
.tbl{width:100%;border-collapse:collapse;margin:16px 0 24px;font-size:14px;border-radius:var(--r);overflow:hidden;border:1px solid var(--border)}
.tbl th{background:var(--cream2);padding:11px 16px;text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:var(--ink3);font-weight:600;border-bottom:1px solid var(--border)}
.tbl td{padding:11px 16px;border-bottom:1px solid var(--border);line-height:1.5;vertical-align:top}
.tbl tr:last-child td{border-bottom:none}
.tbl td:first-child{font-weight:600;color:var(--rust);font-size:13px}
.tbl tr:nth-child(even) td{background:rgba(253,248,242,.6)}

/* ── QUIZ ── */
.quiz{background:#fff;border:1.5px solid var(--border);border-radius:16px;padding:28px;margin-top:40px;box-shadow:var(--shadow)}
.quiz-tag{display:inline-flex;align-items:center;gap:6px;background:var(--rust);color:#fff;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;padding:4px 12px;border-radius:99px;margin-bottom:16px}
.quiz-question{font-family:var(--serif);font-size:20px;font-weight:300;line-height:1.4;margin-bottom:20px;color:var(--ink)}
.quiz-opts{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.quiz-opt{background:var(--cream);border:1.5px solid var(--border);border-radius:10px;padding:14px 18px;cursor:pointer;font-size:15px;text-align:left;transition:all .2s;color:var(--ink2);font-family:var(--sans);line-height:1.4;display:flex;align-items:flex-start;gap:12px}
.quiz-opt:hover{border-color:var(--rust);background:var(--rust-light);color:var(--ink)}
.quiz-opt-letter{width:24px;height:24px;border-radius:50%;background:var(--cream2);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;font-family:var(--mono);transition:all .2s}
.quiz-opt:hover .quiz-opt-letter{background:var(--rust);color:#fff;border-color:var(--rust)}
.quiz-opt.correct{border-color:var(--green);background:var(--green-light);color:var(--green)}
.quiz-opt.correct .quiz-opt-letter{background:var(--green);color:#fff;border-color:var(--green)}
.quiz-opt.wrong{border-color:#dc2626;background:#fef2f2;color:#991b1b}
.quiz-opt.wrong .quiz-opt-letter{background:#dc2626;color:#fff;border-color:#dc2626}
.quiz-opt:disabled{cursor:default}
.quiz-feedback{display:none;border-radius:10px;padding:14px 18px;font-size:14px;line-height:1.65;margin-bottom:16px}
.quiz-feedback.show{display:block}
.quiz-feedback.ok{background:var(--green-light);color:var(--green);border:1px solid #a7f3d0}
.quiz-feedback.no{background:#fef2f2;color:#991b1b;border:1px solid #fecaca}
.quiz-footer{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.quiz-count{font-size:12px;color:var(--ink3);font-family:var(--mono)}
.quiz-next{background:var(--rust);color:#fff;border:none;padding:11px 24px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;display:none;transition:all .2s;font-family:var(--sans)}
.quiz-next:hover{background:#a84020}
.quiz-score{font-size:13px;font-weight:600;color:var(--green)}

/* ── BOTTOM NAV ── */
.lesson-footer{display:flex;justify-content:space-between;align-items:center;margin-top:48px;padding-top:24px;border-top:1px solid var(--border);flex-wrap:wrap;gap:12px}
.btn-back,.btn-next{display:inline-flex;align-items:center;gap:6px;padding:12px 22px;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;border:1.5px solid;font-family:var(--sans)}
.btn-back{background:#fff;color:var(--ink3);border-color:var(--border)}
.btn-back:hover{border-color:var(--cream3);color:var(--ink)}
.btn-next{background:var(--rust);color:#fff;border-color:var(--rust)}
.btn-next:hover{background:#a84020;transform:translateY(-1px);box-shadow:0 4px 16px rgba(196,82,42,.35)}
.btn-done{background:var(--cream2);color:var(--green);border:1.5px solid var(--border);border-radius:10px;padding:12px 22px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;font-family:var(--sans);transition:all .2s}
.btn-done:hover{background:var(--green-light);border-color:var(--green)}
.btn-done.done{background:var(--green-light);border-color:var(--green);color:var(--green);cursor:default}

/* Completion banner */
.completion-banner{background:linear-gradient(135deg,#0d2d1a,#1a5c38);color:#d8f3dc;border-radius:16px;padding:32px;text-align:center;margin-top:24px;display:none}
.completion-banner.show{display:block;animation:fadeUp .5s ease}
.completion-banner .big-emoji{font-size:52px;margin-bottom:12px;display:block}
.completion-banner h3{font-family:var(--serif);font-size:24px;font-weight:300;margin-bottom:8px;color:#d8f3dc}
.completion-banner p{font-size:14px;color:#a7d9b8;max-width:400px;margin:0 auto}

/* ── CERT PAGE ── */
.cert-cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin:20px 0}
.cert-card{background:#fff;border:1.5px solid var(--border);border-radius:16px;padding:24px;text-align:center}
.cert-badge-icon{font-size:44px;margin-bottom:12px;display:block;filter:grayscale(1);transition:filter .3s}
.cert-card.earned .cert-badge-icon{filter:none}
.cert-card.earned{border-color:var(--green);background:var(--green-light)}
.cert-name{font-family:var(--serif);font-size:16px;font-weight:500;margin-bottom:6px;color:var(--ink)}
.cert-sub{font-size:12px;color:var(--ink3);line-height:1.5;margin-bottom:12px}
.cert-progress{font-size:11px;font-family:var(--mono);color:var(--ink3)}
.cert-progress.earned-label{color:var(--green);font-weight:600}

@media(max-width:860px){
  .sidebar{transform:translateX(-100%)}
  .sidebar.open{transform:translateX(0)}
  .main{margin-left:0}
  .content{padding:28px 20px 60px}
  .chapter-grid{grid-template-columns:1fr}
  .hero-card{padding:28px 24px}
  .hero-title{font-size:28px}
  .menu-btn{display:block}
  .topbar{padding:0 16px}
  .stats-row{grid-template-columns:repeat(3,1fr);gap:8px}
  .stat-box{padding:12px}
  .stat-val{font-size:22px}
}
</style>
</head>
