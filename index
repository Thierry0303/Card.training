      <button class="quiz-opt" onclick="answer('1-3',2,2)"><span class="quiz-opt-letter">C</span>Monday or Tuesday — after clearing and settlement</button>
      <button class="quiz-opt" onclick="answer('1-3',3,2)"><span class="quiz-opt-letter">D</span>When you check your statement at the end of the month</button>
    </div>
    <div class="quiz-feedback" id="qfb-1-3"></div>
